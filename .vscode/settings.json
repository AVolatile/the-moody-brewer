angle\\(\\[0, 60, 8, 280\\], fill=hex_to_rgb\\(colors\\['accent'\\]\\)\\)\n\n# Featured menu card section \\(left side of light area\\)\ncard1_x, card1_y = 40, 330\ncard1_w, card1_h = 440, 320\ndraw\\.rounded_rectangle\\(\n    \\[card1_x, card1_y, card1_x \\+ card1_w, card1_y \\+ card1_h\\],\n    radius=20,\n    fill=hex_to_rgb\\(colors\\['bg_dark'\\]\\),\n    outline=hex_to_rgb\\(colors\\['accent'\\]\\),\n    width=3\n\\)\n\n# Draw a coffee/drink image placeholder with gradient\ndrink_x, drink_y = card1_x \\+ 20, card1_y \\+ 20\ndrink_w, drink_h = 400, 180\nfor i in range\\(drink_h\\):\n    ratio = i / drink_h\n    # Create coffee color gradient\n    r = int\\(139 \\+ \\(69 \\* ratio\\)\\)\n    g = int\\(69 \\+ \\(45 \\* ratio\\)\\)\n    b = int\\(19 \\+ \\(35 \\* ratio\\)\\)\n    draw\\.line\\(\\[\\(drink_x, drink_y \\+ i\\), \\(drink_x \\+ drink_w, drink_y \\+ i\\)\\], fill=\\(r, g, b\\), width=1\\)\n\n# Draw accent accent on drink card\ndraw\\.ellipse\\(\\[drink_x \\+ 80, drink_y \\+ 40, drink_x \\+ 140, drink_y \\+ 100\\], \n             fill=hex_to_rgb\\(colors\\['accent'\\]\\)\\)\n\n# Featured menu card section \\(right side of light area\\)\ncard2_x, card2_y = 544, 330\ncard2_w, card2_h = 440, 320\ndraw\\.rounded_rectangle\\(\n    \\[card2_x, card2_y, card2_x \\+ card2_w, card2_y \\+ card2_h\\],\n    radius=20,\n    fill=hex_to_rgb\\(colors\\['bg_light'\\]\\),\n    outline=hex_to_rgb\\(colors\\['bronze'\\]\\),\n    width=2\n\\)\n\n# Add subtle pattern inside\nfor x in range\\(card2_x \\+ 20, card2_x \\+ card2_w - 20, 80\\):\n    for y in range\\(card2_y \\+ 20, card2_y \\+ card2_h - 20, 80\\):\n        draw\\.ellipse\\(\\[x, y, x \\+ 60, y \\+ 60\\], \n                     fill=hex_to_rgb\\(colors\\['muted'\\]\\),\n                     outline=hex_to_rgb\\(colors\\['accent'\\]\\),\n                     width=1\\)\n\n# Button simulation on card 1 \\(accent button\\)\nbtn1_x, btn1_y = card1_x \\+ 240, card1_y \\+ 270\nbtn1_w, btn1_h = 200, 35\ndraw\\.rounded_rectangle\\(\n    \\[btn1_x, btn1_y, btn1_x \\+ btn1_w, btn1_y \\+ btn1_h\\],\n    radius=17,\n    fill=hex_to_rgb\\(colors\\['accent'\\]\\)\n\\)\n\n# Button simulation on card 2 \\(secondary button\\)\nbtn2_x, btn2_y = card2_x \\+ 240, card2_y \\+ 270\nbtn2_w, btn2_h = 200, 35\ndraw\\.rounded_rectangle\\(\n    \\[btn2_x, btn2_y, btn2_x \\+ btn2_w, btn2_y \\+ btn2_h\\],\n    radius=17,\n    fill=hex_to_rgb\\(colors\\['bronze'\\]\\),\n    outline=hex_to_rgb\\(colors\\['bronze'\\]\\),\n    width=2\n\\)\n\n# Service/features grid at bottom \\(4 small cards\\)\nservices_start_y = 730\nservice_cards = \\[\n    \\(44, services_start_y, 220, 100, \"☕ Signature\\\\nLattes\"\\),\n    \\(284, services_start_y, 220, 100, \"🌿 Seasonal\\\\nRefreshers\"\\),\n    \\(524, services_start_y, 220, 100, \"🥐 Fresh\\\\nBites\"\\),\n    \\(764, services_start_y, 220, 100, \"🎨 Local\\\\nFlavor\"\\),\n\\]\n\nfor sx, sy, sw, sh, label in service_cards:\n    draw\\.rounded_rectangle\\(\\[sx, sy, sx \\+ sw, sy \\+ sh\\], \n                          radius=12,\n                          fill=hex_to_rgb\\(colors\\['brown'\\]\\),\n                          outline=hex_to_rgb\\(colors\\['accent'\\]\\),\n                          width=2\\)\n\n# Decorative elements - coffee bean shapes \\(circles positioned artfully\\)\nbean_positions = \\[\n    \\(150, 150, 40\\),\n    \\(850, 200, 35\\),\n    \\(100, 780, 45\\),\n    \\(920, 850, 38\\),\n    \\(500, 950, 30\\),\n\\]\n\nfor bx, by, br in bean_positions:\n    draw\\.ellipse\\(\\[bx - br, by - br, bx \\+ br, by \\+ br\\],\n                fill=hex_to_rgb\\(colors\\['accent'\\]\\),\n                outline=hex_to_rgb\\(colors\\['muted'\\]\\),\n                width=2\\)\n\n# Add central circular element as logo placeholder\nlogo_x, logo_y, logo_r = 512, 470, 80\ndraw\\.ellipse\\(\\[logo_x - logo_r, logo_y - logo_r, logo_x \\+ logo_r, logo_y \\+ logo_r\\],\n            fill=hex_to_rgb\\(colors\\['accent'\\]\\),\n            outline=hex_to_rgb\\(colors\\['text_warm'\\]\\),\n            width=3\\)\n\n# Inner circle\ndraw\\.ellipse\\(\\[logo_x - logo_r \\+ 15, logo_y - logo_r \\+ 15, \n             logo_x \\+ logo_r - 15, logo_y \\+ logo_r - 15\\],\n            fill=hex_to_rgb\\(colors\\['bg_light'\\]\\)\\)\n\n# Navigation dots or accent indicators\nnav_y = 95\nfor i in range\\(5\\):\n    nx = 80 \\+ \\(i \\* 80\\)\n    size = 6 if i == 1 else 4\n    draw\\.ellipse\\(\\[nx - size, nav_y - size, nx \\+ size, nav_y \\+ size\\],\n                fill=hex_to_rgb\\(colors\\['accent'\\]\\)\\)\n\n# Top accent bar with texture\nfor x in range\\(0, width, 5\\):\n    draw\\.line\\(\\[\\(x, 55\\), \\(x \\+ 2, 55\\)\\], fill=hex_to_rgb\\(colors\\['accent'\\]\\), width=2\\)\n\n# Save the image\noutput_path = '/Users/avolatile/Desktop/Projects/Moody Brewer/Website/moody-brewer-website/moody-brewer-portfolio-spotlight\\.png'\nimage\\.save\\(output_path, 'PNG'\\)\n\nprint\\(f\"✓ Portfolio spotlight image generated: \\{output_path\\}\"\\)\nprint\\(f\"✓ Dimensions: 1024x1024\"\\)\nprint\\(f\"✓ File size: \\{Image\\.open\\(output_path\\)\\.size\\}\"\\)\n\nEOF\n$/": {
