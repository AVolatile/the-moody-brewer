# Netlify import template for this project.
# Import this file into Netlify:
# Project configuration > Environment variables > Add a variable > Import from a .env file
#
# Notes:
# - NETLIFY_DATABASE_URL and NETLIFY_DATABASE_URL_UNPOOLED are usually created by the Neon integration.
# - If those are already present in Netlify, do not overwrite them with blanks.
# - Prefer ADMIN_PASSWORD_HASH over ADMIN_PASSWORD.

# NETLIFY_DATABASE_URL=already-set-by-netlify-neon
# NETLIFY_DATABASE_URL_UNPOOLED=already-set-by-netlify-neon

ADMIN_USERNAME=moodybrewer-admin
ADMIN_PASSWORD_HASH=mb1$paste-generated-hash-here
# ADMIN_PASSWORD=use-only-if-you-are-not-using-a-hash
ADMIN_SESSION_SECRET=paste-a-long-random-secret-here
